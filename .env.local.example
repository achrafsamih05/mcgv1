# ============================================================================
#  MCG GLOBAL — Environment Configuration
#  Copy this file to `.env.local` (git-ignored) and fill in real values.
#  On Vercel, add the same keys under Project → Settings → Environment Variables.
# ============================================================================

# Public — safe to expose to the browser (used by the client component).
# Project URL from Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key from Supabase → Settings → API. RLS still applies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — server-only. NEVER prefix with NEXT_PUBLIC and never import it
# into a client component. Bypasses Row Level Security for trusted admin
# overrides (e.g. Super Admin cross-tenant operations in Route Handlers).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
